# Get your FREE Groq API key at: https://console.groq.com
# No credit card required — sign up and create a key in 1 minute
GROQ_API_KEY=your_groq_api_key_here

# Model — llama-3.3-70b-versatile is the best free model on Groq right now
GROQ_MODEL=llama-3.3-70b-versatile

# Internal config (leave as-is for local development)
CHROMA_PERSIST_DIR=./vector_store
BACKEND_URL=http://localhost:8000
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
